<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.exam.controller.StudentController">

    <Label fx:id="welcomeLabel" text="Student Dashboard"/>

    <Label text="Select Exam Paper:"/>
    <ComboBox fx:id="paperComboBox" prefWidth="200" promptText="Choose a Paper"/>
    <Label fx:id="messageLabel" style="-fx-text-fill: red;"/>

    <Button text="Start Exam" onAction="#handleStartExam"/>
    
    <Button text="View Results" onAction="#handleViewResults"/>

    <Button text="Logout" onAction="#handleLogout"/>

</VBox>