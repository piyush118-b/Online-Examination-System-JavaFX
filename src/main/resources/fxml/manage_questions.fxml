<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<HBox spacing="15" xmlns:fx="http://javafx.com/fxml" fx:controller="com.exam.controller.ManageQuestionController">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <VBox spacing="10" prefWidth="250">
        <Label fx:id="contextLabel" text="Questions for Paper" style="-fx-font-weight: bold;"/>
        <ListView fx:id="questionListView" VBox.vgrow="ALWAYS"/>
        <Button text="Clear Selection / New Question" onAction="#handleClearSelection" prefWidth="250"/>
        <Button text="Back to Papers" onAction="#handleBack" prefWidth="250"/>
    </VBox>

    <ScrollPane fitToWidth="true" HBox.hgrow="ALWAYS">
        <content>
            <VBox spacing="12" alignment="CENTER_LEFT">

                <padding>
                    <Insets right="20" bottom="20" left="20"/>
                </padding>

                <Label fx:id="formTitleLabel" text="Add New Question" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

                <Label text="Section"/>
                <ComboBox fx:id="sectionBox" prefWidth="250"/>

                <Label text="Question"/>
                <TextArea fx:id="questionText" promptText="Enter Question" prefHeight="100" wrapText="true"/>

                <Button text="Add Image" onAction="#handleAddImage"/>
                <VBox fx:id="selectedImagesBox" spacing="5" alignment="CENTER_LEFT"/>

                <Label text="Option A"/>
                <TextField fx:id="optionA" promptText="Option A"/>

                <Label text="Option B"/>
                <TextField fx:id="optionB" promptText="Option B"/>

                <Label text="Option C"/>
                <TextField fx:id="optionC" promptText="Option C"/>

                <Label text="Option D"/>
                <TextField fx:id="optionD" promptText="Option D"/>

                <Label text="Correct Option (A/B/C/D)"/>
                <TextField fx:id="correctOption" promptText="Enter A, B, C, or D"/>

                <Label text="Marks"/>
                <TextField fx:id="marks" promptText="Enter Marks"/>

                <HBox spacing="10">
                    <Button text="Save Question" prefWidth="120" onAction="#handleSaveQuestion"/>
                    <Button text="Update Question" fx:id="updateButton" prefWidth="120" onAction="#handleUpdateQuestion" disable="true"/>
                    <Button text="Delete Question" fx:id="deleteButton" prefWidth="120" onAction="#handleDeleteQuestion" disable="true"/>
                </HBox>

                <Label fx:id="messageLabel" style="-fx-text-fill: red;"/>

            </VBox>
        </content>
    </ScrollPane>
</HBox>
