<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="15"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.exam.controller.ViewResultsController">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label fx:id="studentInfoLabel" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <TableView fx:id="resultsTable" prefHeight="250" prefWidth="550">
        <columns>
            <TableColumn fx:id="paperNameCol" text="Exam Paper" prefWidth="200"/>
            <TableColumn fx:id="scoreCol" text="Score" prefWidth="100"/>
            <TableColumn fx:id="totalMarksCol" text="Total Marks" prefWidth="100"/>
            <TableColumn fx:id="valDateCol" text="Date Attempted" prefWidth="150"/>
        </columns>
    </TableView>

    <HBox spacing="10" alignment="CENTER">
        <Button text="Review Selected Attempt" onAction="#handleReviewAttempt"/>
        <Button text="Back to Dashboard" onAction="#handleBack"/>
    </HBox>

</VBox>
